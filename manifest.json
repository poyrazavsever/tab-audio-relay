{
  "manifest_version": 3,
  "name": "Audio Bridge: Seamless Tab Sync",
  "version": "1.0.0",
  "description": "Farklı tarayıcı sekmeleri arasındaki ses oynatma durumlarını birbirine bağlar.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Audio Bridge",
    "default_icon": {
      "16": "assets/logo.png",
      "48": "assets/logo.png",
      "128": "assets/logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "toggle_bridge": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Audio Bridge'i Aç/Kapat"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "audio-bridge@poyraz.com",
      "strict_min_version": "109.0"
    }
  }
}
